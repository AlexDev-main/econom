{
  "info": {
    "name": "Authentication Service",
    "description": "Coleccion Postman para probar login, refresh, logout y SSO simulado.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminEmail", "value": "test-admin@local" },
    { "key": "adminPassword", "value": "test-admin-password" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "ssoLocation", "value": "" },
    { "key": "ssoCode", "value": "" },
    { "key": "ssoState", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Envelope success', function () { pm.expect(json.success).to.eql(true); });",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Logout success', function () { pm.expect(json.success).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - SSO Redirect (302)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/sso",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "sso"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 302', function () { pm.response.to.have.status(302); });",
              "var location = pm.response.headers.get('Location');",
              "pm.collectionVariables.set('ssoLocation', location || '');",
              "if (location) {",
              "  var parsed = new URL(location);",
              "  pm.collectionVariables.set('ssoCode', parsed.searchParams.get('code') || '');",
              "  pm.collectionVariables.set('ssoState', parsed.searchParams.get('state') || '');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - SSO Callback",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/sso/callback?code={{ssoCode}}&state={{ssoState}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "sso", "callback"],
          "query": [
            { "key": "code", "value": "{{ssoCode}}" },
            { "key": "state", "value": "{{ssoState}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Login Incorrecto (AUTH-002)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"incorrect-password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 401', function () { pm.response.to.have.status(401); });",
              "var json = pm.response.json();",
              "pm.test('Code AUTH-002', function () { pm.expect(json.code).to.eql('AUTH-002'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Refresh Invalido (AUTH-004)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"not-a-valid-refresh-token\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 401', function () { pm.response.to.have.status(401); });",
              "var json = pm.response.json();",
              "pm.test('Code AUTH-004', function () { pm.expect(json.code).to.eql('AUTH-004'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - OpenAPI JSON",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v3/api-docs",
          "host": ["{{baseUrl}}"],
          "path": ["v3", "api-docs"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has OpenAPI field', function () { pm.expect(json.openapi).to.exist; });"
            ]
          }
        }
      ]
    }
  ]
}

